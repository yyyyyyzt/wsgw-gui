# 可选：指定要加载的 env 文件绝对路径（会覆盖同名变量）
# WSGW_ENV_FILE=C:\path\to\.env

# Chrome 远程调试：二选一（或同时设置时优先使用完整 ws 地址）
# 方式 A：完整 CDP WebSocket（来自 chrome://inspect 或 http://127.0.0.1:9222/json/version 的 webSocketDebuggerUrl）
# WSGW_CDP_WS_URL=ws://127.0.0.1:9222/devtools/browser/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 方式 B：仅端口号，脚本会请求 http://127.0.0.1:<端口>/json/version 解析 webSocketDebuggerUrl
# 若未设置 WSGW_CDP_WS_URL 也未设置本项，应用会默认使用 9222
WSGW_DEBUG_PORT=9222

# 可选：探活前让当前页导航到该 URL（须用户显式配置；留空则只读取当前标签页 URL，不发起任意导航）
# WSGW_DEMO_URL=https://example.com/

# 可选：开发时若 bundle 未生成，可指向本地脚本绝对路径
# WSGW_MIDSCENE_SCRIPT=C:\path\to\midscene-minimal.mjs

# 可选：从 /json/version 解析 webSocketDebuggerUrl 时的重试（里程碑 B2，仅端口模式）
# WSGW_CDP_RESOLVE_RETRIES=5
# WSGW_CDP_RESOLVE_DELAY_MS=400
